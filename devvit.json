{
  "name": "codederby",
  "displayName": "Code Derby - Fantasy OSS League",
  "version": "0.3.0",
  "description": "Pick 3 GitHub repositories. Watch them rise. Win the week.",
  "web": {
    "entry": "src/client/index.html",
    "domainAllowlist": [
      "api.github.com"
    ]
  },
  "post": {
    "dir": "dist",
    "entrypoints": {
      "default": {
        "entry": "index.html",
        "height": "tall"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "menu": {
    "items": [
      {
        "label": "Create a new post",
        "description": "codederby",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-create"
      }
    ]
  },
  "triggers": {
    "onAppInstall": "/internal/on-app-install"
  },
  "marketingAssets": {
    "icon": "assets/icon.png"
  }
}
