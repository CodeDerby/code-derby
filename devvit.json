{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "codederby",
  "post": {
    "dir": "public",
    "entrypoints": {
      "default": {
        "entry": "index.html",
        "height": "tall"
      }
    }
  },
  "server": {
    "entry": "src/server/index.js"
  },
  "blocks": {
    "entry": "src/main.jsx"
  },
  "permissions": {
    "http": {
      "enable": true,
      "domains": [
        "api.github.com",
        "oauth.reddit.com"
      ]
    },
    "redis": true,
    "reddit": {
      "enable": true,
      "scope": "user",
      "asUser": [
        "SUBMIT_POST"
      ]
    }
  },
  "scheduler": {
    "tasks": {
      "daily-settle": {
        "endpoint": "/internal/cron/settle",
        "cron": "0 0 * * *"
      },
      "weekly-new-round": {
        "endpoint": "/internal/cron/new-round",
        "cron": "0 0 * * MON"
      },
      "weekly-autopost": {
        "endpoint": "/internal/cron/weekly-autopost",
        "cron": "5 0 * * MON"
      }
    }
  },
  "marketingAssets": {
    "icon": "public/assets/icon.png"
  },
  "dev": {
    "subreddit": "codederby_dev"
  }
}