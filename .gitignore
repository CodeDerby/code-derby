# Code Derby (core) — .gitignore

# Node / Devvit
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build output / caches / coverage
dist/
build/
.cache/
.parcel-cache/
.turbo/
coverage/
.nyc_output/

# Devvit local state
.devvit/
.devvit-state/
devvit-debug.log

# Environment & secrets (DO NOT COMMIT SECRETS)
.env
.env.*.local
*.local
*.secret
*.key
*.pem
*.p12
*.pfx
*.jks
*.keystore

# OS / editors
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# Misc
*.log
*.tmp
*.bak
*.orig
